<Window x:Class="Pr4_Zasetsky_Kosarikov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 Засецкий Косариков" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="88*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Практическая работа №4"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,20"/>

        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Width="250" Grid.RowSpan="2">

            <TextBlock Text="Выберите страницу:" 
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>
            <Button Content="Страница 1" 
                    Height="45" Width="200"
                    FontSize="14"
                    Click="Page1Button_Click">
                <Button.ToolTip>
                    <ToolTip Content="Перейти на первую страницу - расчет функции"/>
                </Button.ToolTip>
            </Button>

            <Button Content="Страница 2" 
                    Height="45" Width="200"
                    Margin="0 10"
                    FontSize="14"
                    Click="Page2Button_Click">
                <Button.ToolTip>
                    <ToolTip Content="Перейти на вторую страницу - выбор функции f(x)"/>
                </Button.ToolTip>
            </Button>
            <Button Content="Страница 3" 
                    Height="45" Width="200"
                    FontSize="14"
                    Click="Page3Button_Click">
                <Button.ToolTip>
                    <ToolTip Content="Перейти на третью страницу - таблица и график"/>
                </Button.ToolTip>
            </Button>
        </StackPanel>

        <Button Grid.Row="3" 
                Content="Выход" 
                Height="40" Width="150"
                HorizontalAlignment="Center"
                Margin="0,20,0,20"
                FontSize="14"
                Click="ExitButton_Click">
            <Button.ToolTip>
                <ToolTip Content="Выйти из приложения"/>
            </Button.ToolTip>
        </Button>
    </Grid>
</Window>